PORT=8080
HIFZLINK_ADMIN_USER=
HIFZLINK_ADMIN_PASS=
HIFZLINK_UMAMI_ID=

# Quran Foundation OAuth2 (qf-api branch)
# Pre-production: https://prelive-oauth2.quran.foundation
# Production:     https://oauth2.quran.foundation
QF_CLIENT_ID=
QF_CLIENT_SECRET=
QF_AUTH_ENDPOINT=https://prelive-oauth2.quran.foundation
# Pre-production: https://apis-prelive.quran.foundation
# Production:     https://apis.quran.foundation
QF_API_BASE=https://apis-prelive.quran.foundation
# Override auto-detected redirect URI if host header differs from the registered URI
QF_REDIRECT_URI=https://hifz.click/auth/callback
